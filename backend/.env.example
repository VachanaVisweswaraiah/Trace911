# Copy to .env and fill in.

APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# SQLite. Use sqlite+aiosqlite:///:memory: for ephemeral test runs.
DATABASE_URL=sqlite+aiosqlite:///./trace911.db
DB_ECHO=false

# ai-coustics (LiveKit plugin reads this)
AI_COUSTICS_API_KEY=

# Gladia STT
GLADIA_API_KEY=

# LLM provider (choose one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Audio / pipeline tuning
AIC_MODEL=QUAIL_VF_L
AIC_ENHANCEMENT_LEVEL=0.8
AIC_VAD_SENSITIVITY=6.0
AIC_VAD_SPEECH_HOLD=0.03
AIC_VAD_MIN_SPEECH=0.0
